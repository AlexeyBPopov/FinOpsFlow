<form method="get" class="card card-body mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <input name="Keyword" value="@Model.Keyword"
                   class="form-control" placeholder="Search title or description..." />
        </div>
        <div class="col-md-2">
            <select name="StatusFilter" class="form-select">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<RequestStatus>())
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="PriorityFilter" class="form-select">
                <option value="">All Priorities</option>
                @foreach (var p in Enum.GetValues<RequestPriority>())
                {
                    <option value="@p" selected="@(Model.PriorityFilter == p)">@p</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="CategoryFilter" asp-items="Model.Categories" class="form-select">
                <option value="">All Categories</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="AssignedToFilter" asp-items="Model.Users" class="form-select">
                <option value="">All Assignees</option>
            </select>
        </div>
        <div class="col-md-2">
            <input name="CreatedFrom" value="@Model.CreatedFrom?.ToString("yyyy-MM-dd")"
                   class="form-control" type="date" placeholder="From" />
        </div>
        <div class="col-md-2">
            <input name="CreatedTo" value="@Model.CreatedTo?.ToString("yyyy-MM-dd")"
                   class="form-control" type="date" placeholder="To" />
        </div>
        <div class="col-md-2 d-flex align-items-center">
            <div class="form-check">
                <input name="OverdueOnly" value="true" type="checkbox"
                       class="form-check-input" @(Model.OverdueOnly ? "checked" : "") />
                <label class="form-check-label text-danger fw-semibold">Overdue only</label>
            </div>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-outline-secondary">Filter</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>