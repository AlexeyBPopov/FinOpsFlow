@page
@model FinOpsFlow.Web.Pages.Requests.IndexModel
@using FinOpsFlow.Core.Enums
@using FinOpsFlow.Web.Helpers
@{
    ViewData["Title"] = "Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Requests</h2>
    <a asp-page="./Create" class="btn btn-primary">+ New Request</a>
</div>

<form method="get" class="card card-body mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <input name="Keyword" value="@Model.Keyword"
                   class="form-control" placeholder="Search title or description..." />
        </div>
        <div class="col-md-2">
            <select name="StatusFilter" class="form-select">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<RequestStatus>())
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="PriorityFilter" class="form-select">
                <option value="">All Priorities</option>
                @foreach (var p in Enum.GetValues<RequestPriority>())
                {
                    <option value="@p" selected="@(Model.PriorityFilter == p)">@p</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="CategoryFilter" asp-items="Model.Categories" class="form-select">
                <option value="">All Categories</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="AssignedToFilter" asp-items="Model.Users" class="form-select">
                <option value="">All Assignees</option>
            </select>
        </div>
        <div class="col-md-2">
            <input name="CreatedFrom" value="@Model.CreatedFrom?.ToString("yyyy-MM-dd")"
                   class="form-control" type="date" placeholder="From" />
        </div>
        <div class="col-md-2">
            <input name="CreatedTo" value="@Model.CreatedTo?.ToString("yyyy-MM-dd")"
                   class="form-control" type="date" placeholder="To" />
        </div>
        <div class="col-md-2 d-flex align-items-center">
            <div class="form-check">
                <input name="OverdueOnly" value="true" type="checkbox"
                       class="form-check-input" @(Model.OverdueOnly ? "checked" : "") />
                <label class="form-check-label text-danger fw-semibold">Overdue only</label>
            </div>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-outline-secondary">Filter</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>

@if (!Model.Requests.Any())
{
    <div class="alert alert-info">No requests found.</div>
}
else
{
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>Category</th>
                <th>Status</th>
                <th>Priority</th>
                <th>Assigned To</th>
                <th>Due Date</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Requests)
            {
                <tr>
                    <td class="text-muted">@r.Id</td>
                    <td><a asp-page="./Details" asp-route-id="@r.Id">@r.Title</a></td>
                    <td>@r.Category.Name</td>
                    <td><span class="badge @BadgeHelper.StatusBadge(r.Status)">@r.Status</span></td>
                    <td><span class="badge @BadgeHelper.PriorityBadge(r.Priority)">@r.Priority</span></td>
                    <td>@(r.AssignedTo?.FullName ?? "—")</td>
                    <td>@(r.DueDate?.ToString("dd MMM yyyy") ?? "—")</td>
                    <td>@r.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-page="./Details" asp-route-id="@r.Id"
                           class="btn btn-sm btn-outline-primary">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}