@page "{id:int}"
@model FinOpsFlow.Web.Pages.Requests.EditModel
@using FinOpsFlow.Core.Enums
@{
    ViewData["Title"] = "Edit Request";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h2 class="mb-4">Edit Request #@Model.RequestId</h2>

        <form method="post" asp-route-id="@Model.RequestId">
            <div class="mb-3">
                <label asp-for="Input.Title" class="form-label"></label>
                <input asp-for="Input.Title" class="form-control" />
                <span asp-validation-for="Input.Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.Priority" class="form-label"></label>
                    <select asp-for="Input.Priority"
                            asp-items="Html.GetEnumSelectList<RequestPriority>()"
                            class="form-select"></select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.CategoryId" class="form-label">Category</label>
                    <select asp-for="Input.CategoryId"
                            asp-items="Model.Categories"
                            class="form-select"></select>
                    <span asp-validation-for="Input.CategoryId" class="text-danger small"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.DueDate" class="form-label"></label>
                    <input asp-for="Input.DueDate" class="form-control" type="date" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.AssignedToId" class="form-label">Assign To</label>
                <select asp-for="Input.AssignedToId"
                        asp-items="Model.Users"
                        class="form-select">
                    <option value="">— Unassigned —</option>
                </select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-page="./Details" asp-route-id="@Model.RequestId"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}