@page
@model FinOpsFlow.Web.Pages.IndexModel
@using FinOpsFlow.Core.Enums
@using FinOpsFlow.Web.Helpers
@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard</h2>

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card text-bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="fs-1 fw-bold">@Model.Dashboard.TotalOpen</div>
                        <div>Open Requests</div>
                    </div>
                    <div class="fs-1 opacity-50">📋</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card @(Model.Dashboard.TotalOverdue > 0 ? "text-bg-danger" : "text-bg-secondary")">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="fs-1 fw-bold">@Model.Dashboard.TotalOverdue</div>
                        <div>Overdue</div>
                    </div>
                    <div class="fs-1 opacity-50">⚠️</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="fs-1 fw-bold">@Model.Dashboard.CompletedThisMonth</div>
                        <div>Completed This Month</div>
                    </div>
                    <div class="fs-1 opacity-50">✅</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card text-bg-info">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="fs-1 fw-bold">@Model.Dashboard.MyOpenRequests</div>
                        <div>Assigned to Me</div>
                    </div>
                    <div class="fs-1 opacity-50">👤</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Status chart -->
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">Requests by Status</div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="statusChart" style="max-height:260px"></canvas>
            </div>
        </div>
    </div>

    <!-- Recent activity -->
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header">Recent Activity</div>
            <ul class="list-group list-group-flush">
                @foreach (var item in Model.Dashboard.RecentActivity)
                {
                    <li class="list-group-item small">
                        <div class="d-flex justify-content-between">
                            <span>
                                <strong>@item.UserName</strong>
                                @item.Action.ToString().ToLower()
                                <a asp-page="/Requests/Details" asp-route-id="@item.RequestId">
                                    @item.RequestTitle
                                </a>
                            </span>
                            <span class="text-muted text-nowrap ms-2">
                                @item.Timestamp.ToString("dd MMM HH:mm")
                            </span>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

<!-- Priority breakdown -->
<div class="row g-4 mb-4">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Open by Priority</div>
            <ul class="list-group list-group-flush">
                @foreach (var kvp in Model.Dashboard.ByPriority.OrderByDescending(x => (int)x.Key))
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="badge @BadgeHelper.PriorityBadge(kvp.Key)">@kvp.Key</span>
                        <span class="fw-bold">@kvp.Value</span>
                    </li>
                }
            </ul>
        </div>
    </div>

    <!-- Assignee workload (Manager/Admin only) -->
    @if (Model.Dashboard.ByAssignee.Any())
    {
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">Open Requests by Assignee</div>
                <div class="card-body">
                    @foreach (var item in Model.Dashboard.ByAssignee)
                    {
                        var max = Model.Dashboard.ByAssignee.Max(x => x.OpenCount);
                        var pct = max > 0 ? (int)(item.OpenCount * 100.0 / max) : 0;
                        <div class="mb-2">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>@item.Name</span>
                                <span class="fw-bold">@item.OpenCount</span>
                            </div>
                            <div class="progress" style="height:8px">
                                <div class="progress-bar" style="width:@pct%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
        labels: [@Html.Raw(string.Join(",",
                        Model.Dashboard.ByStatus.Keys.Select(k => $"'{k}'")))],
        datasets: [{
        data: [@string.Join(",", Model.Dashboard.ByStatus.Values)],
        backgroundColor: ['#6c757d','#0dcaf0','#ffc107','#198754','#dc3545','#212529']
        }]
        },
        options: {
        plugins: { legend: { position: 'right' } },
        cutout: '65%'
        }
        });
    </script>
}